doctype html
html(lang="ru")
  head
    meta(charset="UTF-8")
    meta(
      content="width=device-width, initial-scale=1, maximum-scale=4"
      name="viewport"
    )
    meta(content="ie=edge" http-equiv="X-UA-Compatible")

    meta(content="#ffffff" name="theme-color")

    block basicSeo
      meta(content="Описание сайта" name="description")
      meta(content="Ключевые слова" name="keywords")
      meta(content="Страница сайта" property="og:title")
      meta(content="Страница сайта" name="twitter:title")

    meta(content="wotkad" name="author")

    meta(content="summary" name="twitter:card")
    meta(content="" name="twitter:description")
    meta(content="/assets/images/favicons/favicon-96x96.png" name="twitter:image")

    meta(content="" property="og:description")
    meta(content="/assets/images/favicons/favicon-96x96.png" property="og:image")

    link(rel="icon" type="image/png" href="/assets/images/favicons/favicon-96x96.png" sizes="96x96")
    link(rel="icon" type="image/svg+xml" href="/assets/images/favicons/favicon.svg")
    link(rel="shortcut icon" href="/assets/images/favicons/favicon.ico")
    link(rel="apple-touch-icon" sizes="180x180" href="/assets/images/favicons/apple-touch-icon.png")
    meta(name="apple-mobile-web-app-title" content="TTTG")
    link(rel="manifest" href="./../manifest.json")

    block title
      title Топ Трафик | Страница без названия

    script.
      function autorun() {}
      if (window.addEventListener) window.addEventListener("load", autorun, false);
      else window.onload = autorun;
    noscript.
      Похоже у вас отключён Javascript, поэтому вы видете это сообщение.

  body
    .render

    include ../mixins/button/button
    include ../mixins/search/search
    include ../mixins/input/input
    include ../mixins/dropdown/dropdown
    include ../mixins/widget/widget
    include ../mixins/heading/heading
    include ../mixins/heading/heading-table
    include ../components/companies/row
    include ../components/companies/subrow
    include ../components/channel/advertising-campaigns/row
    include ../components/channel/transactions-for-payment/row
    include ../components/channel/administration-history/subrow
    include ../components/admin/admin-channels/subrow
    include ../components/admin/admin-advertising-campaigns/row

    include ../components/campaign/subrow
    
    include ../components/campaign/survey/subrow-survey

    include ../components/campaign/approval-client/subrow-approval-client
    include ../components/campaign/approval-client/row-approval-client

    include ../components/campaign/mediaplan/subrow-mediaplan
    include ../components/campaign/mediaplan/row-mediaplan

    include ../components/campaign/mediaplan-agreed/subrow-mediaplan-agreed
    include ../components/campaign/mediaplan-agreed/row-mediaplan-agreed

    include ../components/campaign/approval/row-approval
    
    include ../components/campaign/coordination/row-coordination

    include ../components/campaign/process-channels/row-process-channels
    include ../components/campaign/process-channels/subrow-process-channels

    include ../components/users/all/row
    include ../components/users/inner/row
    include ../components/users/guests/row


    include ../mixins/breadcrumbs/breadcrumbs
    
    .hidden
      include ../components/icons/_icons

    block content

    include ../components/popups/popup-add-admin
    include ../components/popups/popup-add-link
    include ../components/popups/popup-add-link-table
    include ../components/popups/popup-add-link-links
    include ../components/popups/popup-add-link-mediaplan
    include ../components/popups/popup-add-link-creative
    include ../components/popups/popup-add-link-other
    include ../components/popups/popup-add-channel
    include ../components/popups/popup-delete-post
    include ../components/popups/popup-delete-rk
    include ../components/popups/popup-delete-link
    include ../components/popups/popup-delete-file
    include ../components/popups/popup-delete-all-files
    include ../components/popups/popup-delete-all-channels
    include ../components/popups/popup-share-post
    include ../components/popups/popup-post
    include ../components/popups/popup-delete-admin-post
    include ../components/popups/popup-delete-attachedbill
    include ../components/popups/popup-delete-attachedlink
    include ../components/popups/popup-delete-attachedfile
    include ../components/popups/popup-restore-access
    include ../components/popups/popup-add-user
    include ../components/popups/popup-edit-mode
    include ../components/popups/popup-admin-edit-mode
    include ../components/popups/popup-confirm-changes
    include ../components/popups/popup-check-adaptation
    include ../components/popups/popup-add-tag
