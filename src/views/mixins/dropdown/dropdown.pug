mixin dropdown(data = {})
  - const { defaults, mergeConfig } = require('./_defaults');
  - const modefied = mergeConfig(data, defaults);
  - const hasData = Object.keys(data).some(key => data[key] && data[key].length > 0);

  if hasData 
    .dropdown(class=modefied.class)
      .dropdown__container
        .dropdown__button(class=modefied.color)
          if modefied.icon
            img.dropdown__icon(src=modefied.src, alt=modefied.alt)
          span.dropdown__label= modefied.label
          +button({
            class: 'button-icon sm',
            icon: 'other-angle-down-icon',
          })
        .dropdown__list
          if modefied.links
            each link in modefied.links
              +link({
                class: 'button-with-icon-full sm',
                icon: link.icon,
                title: link.title,
                href: link.href,
              })
          else
            each button, index in modefied.buttons
              label.dropdown__item
                input(type="radio" name=`radio-${modefied.class}` data-color=button.color checked=button.checked)
                p
                  span(class=button.color)= button.title
  else 
    .dropdown(class=defaults.class)
      .dropdown__container
        .dropdown__button
          span.dropdown__label= defaults.label
          +button({
            class: 'button-icon sm',
            icon: 'other-angle-down-icon',
          })
        .dropdown__list
          each button in defaults.buttons
            label.dropdown__item 
              input(type="radio" name="radio" checked=button.checked)
              p= button.title