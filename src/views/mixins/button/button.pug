mixin button(data = {})
  - const { defaults } = require('./_defaults');
  - const hasData = Object.keys(data).some(key => data[key] && data[key].length > 0)

  if hasData
    button(
      type=data.type
      class="button " + data.class
      disabled=data.disabled
      ariaLabel=data.ariaLabel
    )
      if data.icon
        svg
          use(xlink:href="#" + data.icon)
      if data.title
        span(class=data.switchable ? 'narrowed' : '')= data.title
      if data.close
        svg.button-clear
          use(xlink:href="#other-close-icon")
  else
    button(
      type=defaults.type
      class="button button-base"
      ariaLabel=defaults.ariaLabel
    )
      span= defaults.title