mixin button(data = {})
  - const { defaults, mergeConfig } = require('./_defaults');
  - const modefied = mergeConfig(data);
  - const hasData = Object.keys(data).some(key => data[key] && data[key].length > 0)

  if hasData
    button(
      type=modefied.type
      class="button " + modefied.class
      disabled=modefied.disabled
      ariaLabel=modefied.ariaLabel
    )
      if modefied.icon
        svg
          use(xlink:href="#" + modefied.icon)
      if modefied.title
        span(class=modefied.switchable ? 'narrowed' : '')= modefied.title
      if modefied.close
        svg.button-clear
          use(xlink:href="#other-close-icon")
          
  else
    button(
      type=defaults.type
      class=defaults.class
      ariaLabel=defaults.ariaLabel
    )
      span= defaults.title