mixin button(data = {})
  - const { defaults, mergeConfig } = require('./_config');
  - const config = mergeConfig(data, defaults);
  - const hasData = Object.keys(data).some(key => data[key] && data[key].length > 0)

  if hasData
    button(
      type=config.type
      class="button " + config.class
      disabled=config.disabled
      ariaLabel=config.ariaLabel
    )
      if config.icon
        svg
          use(xlink:href="#" + config.icon)
      if data.title
        span(class=config.switchable ? 'narrowed' : '')= data.title
      if config.close
        svg.button-clear
          use(xlink:href="#other-close-icon")
  else
    button(
      type=config.type
      class="button button-base"
      ariaLabel=config.ariaLabel
    )
      span= config.title