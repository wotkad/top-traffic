mixin breadcrumbs(data = {})
  - const { defaults, mergeConfig } = require('./_defaults');
  - const modefied = mergeConfig(data, defaults);
  - const hasData = Object.keys(data).some(key => data[key] && data[key].length > 0)

  if hasData   
    .breadcrumbs
      each link in modefied.values
        if link.href == ''
          span= link.title
          
        else
          a(href=link.href)= link.title
          span /
  else 
    .breadcrumbs
      each link in defaults.values
        if link.href == ''
          span= link.title
          
        else
          a(href=link.href)= link.title
          span /