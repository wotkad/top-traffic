mixin search(data = {})
  - const { defaults, mergeConfig } = require('./_defaults');
  - const modefied = mergeConfig(data);
  
  form(action="#").search
    label.search__label
      input(class="search__input " + modefied.class type="search" required autocomplete="on" placeholder="Поиск..." name="search")
      svg
        use(xlink:href="#other-search-icon")