mixin search(data = {})
  - const defaults = require('./_defaults');
  - const config = { class: data.class !== undefined ? data.class : defaults.class };
  
  form(action="#").search
    label.search__label
      input(class="search__input " + config.class type="search" required autocomplete="on" placeholder="Поиск..." name="search")
      svg
        use(xlink:href="#other-search-icon")