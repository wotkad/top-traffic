mixin input(data = {})
  - const { defaults } = require('./_defaults');
  - const hasData = Object.keys(data).some(key => data[key] && data[key].length > 0)

  if hasData
    if data.model == 'base'
      if data.type == 'password'
        label.input
          input.input__el(disabled=data.disabled type="" + data.type required=data.required autocomplete="on" placeholder="" + data.placeholder name="" + data.name)
          .input__tip= data.placeholder 
          button(type="button").input__toggle
            svg.input__eye
              use(xlink:href="#other-eye-icon")
            svg.input__eye.input__eye-hide
              use(xlink:href="#other-eye-closed-icon")

      else 
        label.input
          input.input__el(disabled=data.disabled type="" + data.type required=data.required autocomplete="on" placeholder="" + data.placeholder name="" + data.name)
          .input__tip= data.placeholder

    else if data.label && data.type !== 'checkbox'
      label.input.input-with-label
        span.input__heading Наименование
          sup *
        .input__container
          input.input__el(class=data.class disabled=data.disabled type="" + data.type required=data.required autocomplete="on" placeholder="" + data.placeholder name="" + data.name)
          .error__text 
            svg
              use(xlink:href="#other-error-icon")
            span Обязательно к заполнению
    
    else if data.min || data.max 
      .input-ranges
        label.input-range
          span от
          input(type="number" min=data.min max=data.max placeholder="от" name="from")
        label.input-range
          span до
          input(type="number" min=data.min max=data.max placeholder="до" name="to")

    else if data.type == 'checkbox' 
      label(class="input-checkbox " + data.class)
        input(type=data.type name="checkbox" checked=data.checked)
        span
        if data.label
          p= data.label

  else
    label.input
      input.input__el(disabled=defaults.disabled type="" + defaults.type required=defaults.required autocomplete="on" placeholder="" + defaults.placeholder name="" + defaults.name)
      .input__tip= defaults.placeholder