mixin badge(data = {})
  - const { defaults, mergeConfig } = require('/assets/js/_defaults/badge/_defaults');
  - const modefied = mergeConfig(data, defaults);

  .badge
    .badge__heading
      svg.badge__icon
        use(xlink:href="#" + modefied.icon)
      .badge__title= modefied.title
      if modefied.tip
        button(type="button" aria-label="button").badge__tip
          svg
            use(xlink:href="#other-info-icon")
          p= modefied.tip.content
    .badge__value= modefied.value