mixin heading(data = {})
  - const { defaults, mergeConfig } = require('/assets/js/_defaults/heading/_defaults-heading');
  - const modefied = mergeConfig(data, defaults);

  .heading
    .heading__container
      .heading__left
        if modefied.isChannel || modefied.isAdmin
          .heading__avatar
            if modefied.image
              img(src=modefied.src, alt=modefied.alt)
            else
              span
        .heading__content
          .heading__top
            h1.heading__title= modefied.title

            if modefied.isChannel || modefied.isAdmin
              +dropdown({
                buttons: [
                  {
                    dataPopupName: 'edit-mode',
                    icon: 'other-edit2-icon',
                    title: 'Режим редактирования',
                  },
                  {
                    dataPopupName: 'delete',
                    icon: 'other-trash-icon',
                    title: 'Удалить',
                  },
                ],
                class: 'dropdown-base heading__dropdown-base',
                isButtons: true,
              })

            if modefied.isRk
              +dropdown({
                buttons: [
                  {
                    icon: 'other-trash-icon',
                    title: 'Удалить',
                  },
                ],
                class: 'dropdown-base heading__dropdown-base',
                isButtons: true,
              })

            if modefied.isChannel || modefied.isAdmin
              +button({
                class: 'heading__addtofavotites',
                icon: 'aside-favorites-icon',
                isOnlyIcon: true,
                view: 'button',
              })

            if modefied.isChannel || modefied.isAdmin
              .heading__status.status(class="status-green") Активный

            if modefied.isRk
              +dropdown({
                buttons: [
                  {
                    color: 'status-green',
                    isChecked: true,
                    title: 'Активный',
                  },
                  {
                    color: 'status-gray',
                    title: 'Неактивный',
                  },
                  {
                    color: 'status-blue',
                    title: 'Новая РК',
                  },
                  {
                    color: 'status-purple',
                    title: 'Подбор каналов',
                  },
                ],
                class: 'dropdown-status heading__dropdown-status',
                color: 'status-green',
                isButtons: true,
                isSelected: true,
                isStatus: true,
                title: 'Активный',
              })

          if modefied.isChannel || modefied.isAdmin
            .heading__bottom
              a(href="https://t.me/" + modefied.tg target="_blank").heading__channel= modefied.tg
              if modefied.isChannel
                .heading__icons
                  svg
                    use(xlink:href="#label-verification-icon")
                  svg
                    use(xlink:href="#label-warning-icon")
                  svg
                    use(xlink:href="#label-scam-icon")
      .heading__right
        .heading__lastupdate
          svg
            use(xlink:href="#other-info-icon")
          span Последнее обновление: 12.12.2023