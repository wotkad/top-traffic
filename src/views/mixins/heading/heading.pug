mixin heading(data = {})
  - const { defaults, mergeConfig } = require('/assets/js/_defaults/heading/_defaults-heading');
  - const modefied = mergeConfig(data, defaults);

  .heading(class=modefied.isAdmin ? 'heading-admin' : '')
    .heading__container
      .heading__left
        if modefied.isChannel || modefied.isAdmin
          .heading__avatar
            if modefied.image
              img(src=modefied.src, alt=modefied.alt)
            else
              span
        .heading__content
          .heading__top
            if modefied.isRk
              h1.heading__title
                span.companies__kp_rk.companies-big КП+РК
                span= modefied.title
            else
              h1.heading__title
                input(type="text" name="title" value=modefied.title placeholder="Введите имя")
                .error-admin 
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <rect width="16" height="16" fill="white" fill-opacity="0.01"/>
