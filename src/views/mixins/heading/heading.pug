                  </svg>
                  span Макс. длина - 60 символов
            if modefied.isChannel
              +dropdown({
                buttons: [
                  {
                    dataPopupName: 'edit-mode',
                    icon: 'other-edit2-icon',
                    title: 'Режим редактирования',
                  },
                  {
                    dataPopupName: 'delete-post',
                    icon: 'other-trash-icon',
                    title: 'Удалить',
                  },
                ],
                class: 'dropdown-base heading__dropdown-base',
                isButtons: true,
              })

            if modefied.isAdmin
              +dropdown({
                buttons: [
                  {
                    dataPopupName: 'admin-edit-mode',
                    icon: 'other-edit2-icon',
                    title: 'Режим редактирования',
                  },
                  {
                    icon: 'other-archive-icon',
                    title: 'Архивировать',
                  },
                  {
                    dataPopupName: 'delete-post',
                    icon: 'other-trash-icon',
                    title: 'Удалить',
                  },
                ],
                class: 'dropdown-base heading__dropdown-base',
                isButtons: true,
              })

            if modefied.isRk
              +dropdown({
                buttons: [
                  {
                    dataPopupName: 'delete-rk',
                    icon: 'other-trash-icon',
                    title: 'Удалить',
                  },
                ],
                class: 'dropdown-base heading__dropdown-base',
                isButtons: true,
              })

            if modefied.isChannel || modefied.isAdmin
              +button({
                class: 'heading__addtofavorites',
                icon: 'aside-favorites-icon',
                isOnlyIcon: true,
                view: 'button',
              })

            if modefied.isChannel || modefied.isAdmin
              .heading__status.status(class="status-green") Активный

            if modefied.isRk
              +dropdown({
                buttons: [
                  {
                    color: 'status-blue',
                    isChecked: true,
                    title: 'Новая РК',
                  },
                  {
                    color: 'status-blue',
                    title: 'Подбор каналов',
                  },
                  {
                    color: 'status-gray',
                    title: 'Отказ',
                  },
                  {
                    color: 'status-blue',
                    title: 'Подтверждение подбора',
                  },
                  {
                    color: 'status-blue',
                    title: 'Опрос канала',
                  },
                  {
                    color: 'status-blue',
                    title: 'Согласование куратором',
                  },
                  {
                    color: 'status-blue',
                    title: 'Согласование клиентом',
                  },
                  {
                    color: 'status-blue',
                    title: 'Медиаплан подтвержден',
                  },
                  {
                    color: 'status-blue',
                    title: 'Медиаплан согласован',
                  },
                  {
                    color: 'status-blue',
                    title: 'В процессе',
                  },
                  {
                    color: 'status-blue',
                    title: 'Завершено',
                  },
                ],
                class: 'dropdown-status heading__dropdown-status',
                color: 'status-blue',
                isButtons: true,
                isSelected: true,
                isStatus: true,
                title: 'Новая РК',
              })

          if modefied.isChannel || modefied.isAdmin
            .heading__bottom
              a(href="https://t.me/" + modefied.tg target="_blank").heading__channel= modefied.tg
                if modefied.isAdmin
                  img(src="/assets/images/max.svg", alt="max" width="12px" height="12px")
                  <svg width="13" height="13" viewBox="0 0 13 13" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <circle cx="6.5" cy="6.5" r="6" fill="white" stroke="#374151"/>
