aside.content-aside
  .content-aside__container
    .selectors
      .selector__buttons
        .selector__scroll
          .selector__button(data-id="information").active Информация
          .selector__button(data-id="posts") Лента
          .selector__button(data-id="chat") Чат
      .selector__containers.selector__content
        .selector__container(data-id="information").active
          .content-aside__subtitle Общая информация
          table.table
            tr.text-black-200
              th Категория
              td Интернет технологии
            tr.text-black-200
              th Гео
              td Россия
            tr.text-black-200
              th Язык канала
              td Русский
            tr.text-black-200
              th Администратор
              td
                .flex.items-center(class="gap-x-[6px]")
                  img.rounded(class="w-6 h-6" src="/assets/images/avatar.png" alt="tg-channel")
                  .text-12-r-p Андрей Миронов
            tr.text-black-200
              th Организация
              td
                .flex.items-center(class="gap-x-[6px]")
                  img.rounded(class="w-6 h-6" src="/assets/images/avatar.png" alt="tg-channel")
                  .text-12-r-p ООО "МедиаКар"
          .content-aside__subtitle Внутренняя информация
          table.table
            tr.text-black-200
              th Менеджер
              td
            tr.text-black-200
              th Приоритет
              td
                +dropdown({
                  buttons: [
                    {
                      color: 'priority-transparent',
                      isChecked: true,
                      title: 'Все',
                    },
                    {
                      color: 'priority-red',
                      title: 'Очень высокий',
                    },
                    {
                      color: 'priority-pink',
                      title: 'Высокий',
                    },
                    {
                      color: 'priority-orange',
                      title: 'Средний',
                    },
                    {
                      color: 'priority-peach',
                      title: 'Низкий',
                    },
                    {
                      color: 'priority-yellow',
                      title: 'Очень низкий',
                    },
                  ],
                  class: 'dropdown-priority',
                  color: 'priority-transparent',
                  isButtons: true,
                  isPriority: true,
                })
          .content-aside__subtitle Поле для комментария
          +input({
            class: 'content-aside__textarea',
            isTextarea: true,
            label: '',
            name: 'comment',
            placeholder: 'Добавить комментарий...',
          })
          .content-aside__subtitle Общая информация
            +dropdown({
              buttons: [
                {
                  dataPopupName: 'upload-file',
                  icon: 'other-new-file-icon',
                  title: 'Файл',
                },
                {
                  dataPopupName: 'add-link',
                  icon: 'other-link-icon',
                  title: 'Ссылка',
                },
              ],
              icon: 'other-add-file-icon',
              isButtons: true,
              subtitle: 'Добавить',
            })
          .accordions
            .accordion
              .accordion__button(data-id="links")
                p Ссылки
                  span 2
                +button({
                  class: 'button-icon sm',
                  icon: 'other-angle-down-icon',
                  isOnlyIcon: true,
                  view: 'button',
                })
              .accordion__container(data-id="links")
                .accordion__item
                  .accordion__left
                    .accordion__icon
                      svg
                        use(xlink:href="#other-link-icon")
                    a(href="https://app.asana.com/" target="_blank") https://app.asana.com/
                    time 24 янв. 15:10
                  .accordion__right
                    +button({
                      class: 'button-icon accordion__action accordion__copy',
                      icon: 'other-copy-icon',
                      isOnlyIcon: true,
                      view: 'button',
                    })
                .accordion__item
                  .accordion__left
                    .accordion__icon
                      svg
                        use(xlink:href="#other-link-icon")
                    a(href="https://app.asana.com/" target="_blank") https://app.asana.com/
                    time 24 янв. 15:10
                  .accordion__right
                    +button({
                      class: 'button-icon accordion__action accordion__copy',
                      icon: 'other-copy-icon',
                      isOnlyIcon: true,
                      view: 'button',
                    })
            .accordion
              .accordion__button(data-id="files")
                p Файлы
                  span 2
                +button({
                  class: 'button-icon sm',
                  icon: 'other-angle-down-icon',
                  isOnlyIcon: true,
                  view: 'button',
                })
              .accordion__container(data-id="files")
                .accordion__item
                  .accordion__left
                    .accordion__icon
                      svg
                        use(xlink:href="#other-file-icon")
                    a(href="#" download) Креативы.zip
                    time 54 KB • 24 янв. 15:10
                  .accordion__right
                    +button({
                      class: 'button-icon accordion__action',
                      href: '#',
                      icon: 'other-download-icon',
                      isDownload: true,
                      isOnlyIcon: true,
                      view: 'link',
                    })
                    +button({
                      class: 'button-icon accordion__action',
                      icon: 'other-trash-icon',
                      isOnlyIcon: true,
                      view: 'button',
                    })
                .accordion__item
                  .accordion__left
                    .accordion__icon
                      svg
                        use(xlink:href="#other-file-icon")
                    a(href="#" download) Креативы new.zip
                    time 54 KB • 24 янв. 15:10
                  .accordion__right
                    +button({
                      class: 'button-icon accordion__action',
                      href: '#',
                      icon: 'other-download-icon',
                      isDownload: true,
                      isOnlyIcon: true,
                      view: 'link',
                    })
                    +button({
                      class: 'button-icon accordion__action',
                      icon: 'other-trash-icon',
                      isOnlyIcon: true,
                      view: 'button',
                    })
        .selector__container(data-id="posts")
        .selector__container(data-id="chat")