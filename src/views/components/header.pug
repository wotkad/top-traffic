header.header
  .header__wrapper
    .header__search
      +button({
        icon: 'other-expand-menu-icon',
        class: 'button-icon sidebar__toggle narrowed',
      })
      +search({
        class: 'transparent',
      })
    .header__controls
      +link({
        class: 'button-icon',
        icon: 'other-notification-icon',
      })
      +link({
        class: 'button-icon',
        icon: 'aside-help-icon',
      })
      +dropdown({
        icon: {
          enabled: true,
          src: '/assets/images/user-icon.png',
          alt: 'icon',
        },
        class: 'dropdown-with-icon header__dropdown',
        value: 'Максим Амбиндер',
        values: [ 
          { value: 'Настройки', icon: 'other-settings-icon' },
          { value: 'Выйти', icon: 'other-logout-icon' } 
        ]
      })