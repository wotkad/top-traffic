.popup__bg(data-popup-name="check-adaptation-channels")
.popup(data-popup-name="check-adaptation-channels")
  .popup__wrapper(data-scroll-lock-scrollable)
    .input__label Наличие адаптации
    form(action="#")
      .popup__labels
        label.popup__label
          input(type="radio" name="adaptation-channels" value="required")
          span Обязательно
        label.popup__label
          input(type="radio" name="adaptation-channels" value="possible")
          span Возможно
        label.popup__label
          input(type="radio" name="adaptation-channels" value="none")
          span Отсутствует
        label.popup__label
          input(type="radio" name="adaptation-channels" value="depends")
          span Зависит от поста
      .popup__form
        .popup__col
          +input({
            class: 'only-numbers',
            isDisabled: true,
            isLabel: true,
            label: 'Доплата за адаптацию',
            smallLabel: '% от себестоимости',
            name: 'adaptation-channels',
            placeholder: '0',
            type: 'text',
            isTip: true,
            tip: `
              Ввод доплаты доступен для вариантов<br>
              <ul>
                <li>Обязательно</li>
                <li>Возможно</li>
                <li>Зависит от поста</li>
              </ul>
            `
          })
          label.mp
            input(type="checkbox" name="mp")
            span Включить в цену МП
    .popup__buttons
      +button({
        class: 'button-base lg',
        dataPopupName: 'check-adaptation-channels',
        title: 'Отмена',
        view: 'button',
      })
      +button({
        class: 'button-with-icon-blue lg',
        dataPopupName: 'check-adaptation-channels',
        isDisabled: true,
        title: 'Сохранить',
        type: 'submit',
        view: 'button',
      })