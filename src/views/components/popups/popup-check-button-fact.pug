4.72168C1.55166 4.64216 1.609 4.57373 1.67969 4.52344L4.46582 2.51855L4.46973 2.51562C4.58296 2.45019 4.71571 2.4328 4.84082 2.4668Z" fill="#959BA4" stroke="#959BA4" stroke-width="0.1"/>
              </svg>
              <div class="input__col">
                <div class="input-small-label">Сумма доплаты</div>
                <div class="input__container">
                  <input class="input__el only-numbers" disabled="" type="text" autocomplete="on" placeholder="0" name="check-button-fact">
                </div>
              </div>
            </div>
          </div>
          span.popup__tipsmall Значения пересчитываются автоматически от себестоимости размещения
    .popup__buttons
      +button({
        class: 'button-base lg',
        dataPopupName: 'check-button-fact',
        title: 'Отмена',
        view: 'button',
      })
      +button({
        class: 'button-with-icon-blue lg',
        dataPopupName: 'check-button-fact',
        isDisabled: true,
        title: 'Сохранить',
        type: 'submit',
        view: 'button',
      })