.popup__bg(data-popup-name="check-button-fact")
.popup(data-popup-name="check-button-fact")
  .popup__wrapper(data-scroll-lock-scrollable)
    .input__label Фактическое наличие кнопки
    form(action="#")
      .popup__labels
        label.popup__label
          input(type="radio" name="check-button-fact" value="integrated")
          span Интегрирована
        label.popup__label
          input(type="radio" name="check-button-fact" value="none")
          span Не интегрирована
      .popup__form
        .popup__col
          <div class="input input-with-label">
            <div class="input__label">Доплата за адаптацию
              <div class="button">
                <svg viewBox="0 0 17 16" width="17" height="16"><use xlink:href="#other-info-icon"></use></svg>
                <span>Ввод доплаты доступен для вариантов<br>
                  <ul>
                    <li>Обязательно</li>
                    <li>Возможно</li>
                    <li>Зависит от поста</li>
                  </ul>
                </span>
              </div>
            </div>
            <div class="input__containers">
              <div class="input__col">
                <div class="input-small-label">% от себестоимости</div>
                <div class="input__container">
                  <input class="input__el only-numbers" disabled="" type="text" autocomplete="on" placeholder="0" name="check-button-fact">
                </div>
              </div>
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
