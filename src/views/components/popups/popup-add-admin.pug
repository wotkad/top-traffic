.popup(data-popup-name="add-admin" data-scroll-lock-scrollable)
  .popup__bg(data-popup-name="add-admin")
  .popup__wrapper
    .popup__title Добавление администратора
      form(action="#")
        .popup__form.popup__form-two-cols
          .popup__col
            +input({
              label: 'Наименование',
              type: 'text',
              placeholder: 'Введите наименование',
              isRequired: true,
              isLabel: true,
              name: 'name',
            })
            +input({
              label: 'Контакт в Телеграм',
              type: 'text',
              placeholder: 'Введите тег',
              isRequired: true,
              isLabel: true,
              name: 'telegram',
            })
            +dropdown({
              class: 'dropdown-checkboxes',
              title: 'Выберите каналы',
              label: 'Каналы',
              isRequired: true,
              isCheckboxes: true,
              checkboxes: [
                { title: 'Все' },
                { title: 'Банки' },
                { title: 'Банки' },
                { title: 'Автомобили' },
                { title: 'Банки' },
                { title: 'Банки' },
                { title: 'Автомобили' },
                { title: 'Автомобили' },
                { title: 'Автомобили' },
                { title: 'Автомобили' },
                { title: 'Автомобили' },
                { title: 'Автомобили' },
                { title: 'Автомобили' },
                { title: 'Автомобили' },
                { title: 'Автомобили' },
                { title: 'Автомобили' },
              ],
            })
            +dropdown({
              class: 'dropdown-checkboxes',
              title: 'Выберите организацию',
              label: 'Организация',
              isCheckboxes: true,
              checkboxes: [
                { title: 'Все' },
                { title: 'Банки' },
                { title: 'Банки' },
                { title: 'Автомобили' },
                { title: 'Банки' },
                { title: 'Банки' },
                { title: 'Автомобили' },
                { title: 'Автомобили' },
                { title: 'Автомобили' },
                { title: 'Автомобили' },
                { title: 'Автомобили' },
                { title: 'Автомобили' },
                { title: 'Автомобили' },
                { title: 'Автомобили' },
                { title: 'Автомобили' },
                { title: 'Автомобили' },
              ],
            })
          .popup__col
            +dropdown({
              class: 'dropdown-priority',
              title: '––',
              label: 'Приоритет',
              isPriority: true,
              isButtons: true,
              buttons: [
                { title: 'Очень высокий', color: 'priority-red' },
                { title: 'Высокий', color: 'priority-pink' },
                { title: 'Средний', color: 'priority-orange' },
                { title: 'Низкий', color: 'priority-peach' },
                { title: 'Очень низкий', color: 'priority-yellow' },
              ],
            })
            +input({
              isTextarea: true,
              label: 'Описание',
              placeholder: 'Добавьте описание...',
              isLabel: true,
              name: 'description',
            })
        .popup__buttons
          +button({
            view: 'button',
            class: 'button-with-icon-blue lg popup__close',
            type: 'submit',
            title: 'Сохранить',
            dataPopupName: 'add-admin',
          })
          +button({
            view: 'button',
            class: 'button-base lg popup__close',
            title: 'Отмена',
            dataPopupName: 'add-admin',
          })