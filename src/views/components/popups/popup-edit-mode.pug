.popup__bg(data-popup-name="edit-mode").active
.popup(data-popup-name="edit-mode").active
  .popup__wrapper(data-scroll-lock-scrollable)
    .popup__heading
      .popup__icon
        svg
          use(xlink:href="#other-edit-mode")
      h2 Режим редактирования
    form(action="#").popup__container
      .popup__controls
        .popup__alert
          svg
            use(xlink:href="#other-warning-icon")
          span Введенные данные не соответствуют автоматике. Обновите данные
        button(type="button").popup__refresh
          svg
            use(xlink:href="#other-refresh-icon")
          span Сбросить данные
      .popup__block
        h2 Основная информация
