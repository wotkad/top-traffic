      .popup__block
        h2 Статистика
        .popup__items
          +input({
            isLabel: true,
            label: 'Подписчики',
            name: 'subscribers',
            placeholder: 'Введите значение',
            type: 'text',
            value: '82 918',
          })
          .input.input-with-label.input__sexes.error
            span.input__label Аудитория
            .input__container
              label.input__sex.input-male
                p М
                input.input__el.input(type="text" name="male" value="52")
                span %
              label.input__sex.input-female
                p Ж
                input.input__el.input(type="text" name="female" value="48")
                span %
            .error__text Автоматическое значение: М (53%), Ж (47%)
          +input({
            isLabel: true,
            label: 'Индекс цитирования (ИЦ)',
            name: 'quote-intex',
            placeholder: 'Введите значение',
            type: 'text',
            value: '2.6',
          })
          .input.input-with-label.input__datas
            span.input__label Уровень вовлеченности
            .input__container
              label.input__data
                p ERR
                input.input__el.input(type="text" name="err")
                span %
              label.input__data
                p ER
                input.input__el.input(type="text" name="er")
                span %
          +input({
            isLabel: true,
            label: 'Охват',
            name: 'count',
            placeholder: 'Введите значение',
            type: 'text',
          })
      .popup__save
        svg
          use(xlink:href="#other-check-icon")
        span Изменения сохранены
      .popup__buttons
        +button({
          class: 'button-base',
          dataPopupName: 'edit-mode',
          title: 'Отменить',
          view: 'button',
        })
        +button({
          class: 'button-with-icon-blue lg',
          dataPopupName: 'edit-mode',
          title: 'Сохранить',
          type: 'submit',
          view: 'button',
        })