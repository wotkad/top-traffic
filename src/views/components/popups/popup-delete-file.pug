.popup__bg(data-popup-name="delete-file")
.popup(data-popup-name="delete-file")
  .popup__wrapper(data-scroll-lock-scrollable)
    .popup__title Подтвердить действие
    .popup__subtitle Удалить файл?
    .popup__form
      .popup__buttons
        +button({
          class: 'button-base',
          dataPopupName: 'delete-file',
          title: 'Нет',
          view: 'button',
        })
        +button({
          class: 'button-confirm',
          dataPopupName: 'delete-file',
          title: 'Да',
          view: 'button',
        })