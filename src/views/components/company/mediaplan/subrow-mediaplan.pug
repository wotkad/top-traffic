mixin subrow-mediaplan(data)
  tr.subrow(class=data.class)
    td.only-text(colspan="14")
      .fixed-subrow
        .flex.items-center(class="gap-x-2.5")
          h3= data.title
          span= data.count
        +button({
          class: 'button-icon sm',
          icon: 'other-angle-down-icon',
          isOnlyIcon: true,
          view: 'button',
        })