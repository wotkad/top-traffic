mixin row-process-channels(data)
  tr
    td(style="min-width: 280px;")
      .flex.items-center(class="gap-x-1.5")
        img.rounded.object-cover(class="w-[30px] h-[30px]" src="/assets/images/avatar.png" alt="tg-channel")
        .flex.flex-col.items-start
          h3
            a(href="#").table__channel ZeroDay | Кибербезопасность
          a(href="https://t.me/cybersec_academy" target="_blank").table__link @cybersec_academy
    td.only-text Интернет технологии
    td
      .grid.items-center(class="gap-x-1.5 grid-cols-[30px_1fr]")
        img.rounded.object-cover(class="w-[30px] h-[30px]" src="/assets/images/avatar.png" alt="tg-channel")
        span Илья Сорокин
    td.only-text ООО “Андрей Миронов”
    td.only-text.text-right 999 999
    td.only-text.text-right 200 600
    td.only-text.text-right 200 500 ₽
    td.only-text.text-right 25,5%
    td.text-right
      .flex.items-center.justify-end
        +input({
          autocomplete: 'off',
          class: 'currency',
          name: 'revenue',
          placeholder: '0',
          type: 'text',
        })
    td.text-right
