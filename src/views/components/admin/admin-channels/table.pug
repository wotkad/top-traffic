table.table.table-fixed-cols.table-can-remove
  thead
    tr
      th(style="padding-left: 12px; min-width: 288px;").fixed-th.fixed-th-border
        .flex.items-center(class="gap-x-3")
          +input({
            class: 'md table__checkbox',
            type: 'checkbox',
          })
          .table__sort.flex.gap-x-2.items-center
            p Канал
              button(type="button").table__sortbutton
                svg
                  use(xlink:href="#other-sort-icon")
      th
        .table__sort.flex.gap-x-2.items-center
          p Категория
            button(type="button").table__sortbutton
              svg
                use(xlink:href="#other-sort-icon")
      th
        .table__sort.flex.gap-x-2.items-center.justify-end
          p Подписчики
            button(type="button").table__sortbutton
              svg
                use(xlink:href="#other-sort-icon")
      th
        .table__sort.flex.gap-x-2.items-center
          p Начало работы
            button(type="button").table__sortbutton
              svg
                use(xlink:href="#other-sort-icon")
      th
        .table__sort.flex.gap-x-2.items-center
          p Окончание работы
            button(type="button").table__sortbutton
              svg
                use(xlink:href="#other-sort-icon")
      th(class="pr-2.5")
  tbody
    +admin-channels-subrow({
      title: 'Активные каналы',
      class: 'subrow-admin',
      count: '3',
    })
    +admin-channels-subrow({
      title: 'Неактивные каналы',
      count: '3',
    })
    include row
    include row
    include row