  .chat__container.active
    .chat__header
      .chat__title
        +button({
          class: 'chat__close',
          icon: 'other-angle-left-lg-icon',
          isOnlyIcon: true,
          view: 'button',
        })
        .chat__avatar(style="background-color: #E5E4FC;")
          span МТС
        .chat__name MTC_KION
        .chat__icon
          svg
            use(xlink:href="#other-telegram-icon")
      .chat__controls
        +button({
          class: 'chat__trigger-search',
          icon: 'other-search-icon',
          isOnlyIcon: true,
          view: 'button',
        })
        +button({
          icon: 'other-more-icon',
          isOnlyIcon: true,
          view: 'button',
        })
    .chat__search
      +search
      .chat__search__buttons
        +button({
          icon: 'other-angle-up-lg-icon',
          isOnlyIcon: true,
          view: 'button',
        })
        +button({
          icon: 'other-angle-down-lg-icon',
          isOnlyIcon: true,
          view: 'button',
        })
      +button({
        icon: 'other-close-icon',
        isOnlyIcon: true,
        view: 'button',
      })
    .chat__messages
      include ./chat-messages