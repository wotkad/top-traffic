.chat
  .chat__pin
    svg
      use(xlink:href="#other-pin-icon")
    span Закрепить
  +search
  .chat__categories
    button(type="button" data-id="chat-all").chat__category.active
      span Все
    button(type="button" data-id="chat-clients").chat__category
      span Клиенты
    button(type="button" data-id="chat-admins").chat__category
      span Администраторы
