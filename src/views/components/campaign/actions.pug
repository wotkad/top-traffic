.messages__bottom
  .messages__footer
    form(action="#").messages__form.default
      +input({
        class: 'messages__upload',
        isFileUpload: true,
        isMultiple: true,
        isRequired: true,
        isTextarea: true,
        label: '',
        name: 'comment',
        placeholder: 'Отправить комментарий...',
      })
      +button({
        class: 'button-icon-round messages__submit',
        icon: 'other-send-icon',
        isDisabled: true,
        isOnlyIcon: true,
        type: 'submit',
        view: 'button',
      })