.chat__bottom
  .chat__footer
    form(action="#").chat__form.default
      +input({
        class: 'chat__upload',
        isFileUpload: true,
        isMultiple: true,
        isRequired: true,
        isTextarea: true,
        label: '',
        name: 'comment',
        placeholder: 'Отправить комментарий...',
      })
      +button({
        class: 'button-icon-round chat__submit',
        icon: 'other-send-icon',
        isDisabled: true,
        isOnlyIcon: true,
        type: 'submit',
        view: 'button',
      })