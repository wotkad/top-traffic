extends ../layouts/master

block title
  title Топ Трафик | Компоненты

block basicSeo
  meta(content="Компоненты" name="description")
  meta(content="Компоненты" name="keywords")
  meta(content="Компоненты" property="og:title")
  meta(content="Компоненты" name="twitter:title")

block manifestBrowserconfigFiles
  link(href="../manifest.json" rel="manifest" crossorigin)
  meta(content="../browserconfig.xml" name="msapplication-config")

block content
  main.components.p-4
    .flex.flex-col.gap-y-4.items-start.p-4.border.rounded-md.mb-4
      h2.text-2xl.font-bold.pb-4.border-b.w-full Кнопки
      +button({
        view: 'button',
        title: 'Да',
        class: 'button-confirm',
      })
      +button({
        view: 'link',
        class: 'button-with-icon',
        icon: 'other-download-icon',
        title: 'Скачать',
        isDownload: true,
      })
      +button({
        view: 'button',
        class: 'button-with-icon',
        icon: 'other-controls-icon',
        title: 'Фильтр',
      })
      +button({
        view: 'button',
        class: 'button-with-icon',
        icon: 'other-controls-icon',
        title: 'Фильтр',
        isClose: true,
      })
      +button({
        view: 'button',
        class: 'button-with-icon-blue',
        icon: 'other-plus-icon',
        title: 'Добавить канал',
      })
      +button({
        view: 'button',
        class: 'button-base',
        title: 'Применить',
      })
      +button({
        view: 'link',
        icon: 'aside-channels-icon',
        title: 'Каналы',
        class: 'button-with-icon-full',
      })
      +breadcrumbs({ values: [ { title: 'Условия', href: '#' }, { title: 'Конфиденциальность', href: ''} ]})
      +breadcrumbs
      +button({
        view: 'button',
        class: 'button-icon',
        icon: 'other-expand-menu-icon',
        isOnlyIcon: true,
      })
      +button({
        view: 'link',
        class: 'button-icon-round',
        icon: 'other-arrow-up-icon',
        isOnlyIcon: true,
      })
      +button({
        view: 'button',
        class: 'button-with-icon-full-lg',
        icon: 'other-arrow-right-icon',
        title: 'Войти',
      })
      +button({
        view: 'link',
        class: 'button-with-icon-full-google',
        icon: 'other-google-icon',
        title: 'Войти с учетной записью Google',
      })
      include ../components/pagination
    .flex.flex-col.gap-y-4.items-start.p-4.border.rounded-md.mb-4
      h2.text-2xl.font-bold.pb-4.border-b.w-full Иконки
      .flex.flex-wrap.gap-4
        include ../components/icons/_icons
    .flex.flex-col.gap-y-4.items-start.p-4.border.rounded-md.mb-4
      h2.text-2xl.font-bold.pb-4.border-b.w-full Цвета
      .flex.flex-wrap.gap-4
        .py-2.px-12.rounded-md.text-12-r-md.bg-black-000.text-white-000 #000000
        .py-2.px-12.rounded-md.text-12-r-md.bg-black-050.text-white-000 #222222
        .py-2.px-12.rounded-md.text-12-r-md.bg-black-100.text-white-000 #374151
