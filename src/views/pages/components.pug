        .py-2.px-12.rounded-md.text-12-r-md.bg-purple-000 #BD6AF0
        .py-2.px-12.rounded-md.text-12-r-md.bg-purple-050 #AD84C9
        .py-2.px-12.rounded-md.text-12-r-md.bg-purple-100 #EBD2FB
        .py-2.px-12.rounded-md.text-12-r-md.bg-purple-200 #E5E4FC
        .py-2.px-12.rounded-md.text-12-r-md.bg-purple-300 #E6EFFE
    .flex.flex-col.gap-y-4.items-start.p-4.border.rounded-md.mb-4
      h2.text-2xl.font-bold.pb-4.border-b.w-full Дропдаун
      .w-full.flex.flex-col.gap-y-4.items-start
        +dropdown
        +dropdown({
          image: {
            enabled: true,
            src: '/assets/images/user-image.png',
            alt: 'icon',
          },
          class: 'dropdown-with-icon',
          title: 'Максим Амбиндер',
          isLinks: true,
          links: [ 
            { title: 'Настройки', href: '#', icon: 'other-settings-icon' },
            { title: 'Выйти', href: '#', icon: 'other-logout-icon' } 
          ],
        })
        +dropdown({
          class: 'dropdown-status',
          color: 'status-transparent',
          isStatus: true,
          isButtons: true,
          title: '––',
          buttons: [ 
            { title: '––', color: 'status-transparent', isChecked: true },
            { title: 'Активный', color: 'status-green'},
            { title: 'Неактивный', color: 'status-gray' },
            { title: 'Новая РК', color: 'status-blue' },
            { title: 'Подбор каналов', color: 'status-purple' },
          ],
        })
        +dropdown({
          class: 'dropdown-checkboxes',
          title: 'Выберите фильтр',
          isCheckboxes: true,
          checkboxes: [
            { title: 'Все' },
            { title: 'Банки' },
            { title: 'Банки' },
            { title: 'Автомобили' },
            { title: 'Банки' },
            { title: 'Банки' },
            { title: 'Автомобили' },
            { title: 'Автомобили' },
            { title: 'Автомобили' },
            { title: 'Автомобили' },
            { title: 'Автомобили' },
            { title: 'Автомобили' },
            { title: 'Автомобили' },
            { title: 'Автомобили' },
            { title: 'Автомобили' },
            { title: 'Автомобили' },
          ],
        })
        +dropdown({
          class: 'dropdown-priority',
          color: 'priority-transparent',
          isPriority: true,
          isButtons: true,
          title: '––',
          buttons: [ 
            { title: '––', color: 'priority-transparent', isChecked: true },
            { title: 'Очень высокий', color: 'priority-red' },
            { title: 'Высокий', color: 'priority-pink' },
            { title: 'Средний', color: 'priority-orange' },
            { title: 'Низкий', color: 'priority-peach' },
            { title: 'Очень низкий', color: 'priority-yellow' },
          ],
        })
    .flex.flex-col.gap-y-4.items-start.p-4.border.rounded-md.mb-4
      h2.text-2xl.font-bold.pb-4.border-b.w-full Типографика (Inter)
      .text-30-m-p 30, Medium, 120% LH
      .text-24-sb 24, Semibold, 30 LH
      .text-18-sb 18, Semibold, 24 LH
      .text-14-m-md 14, Medium, 20 LH
      .text-14-sb 14, Semibold, 18 LH
      .text-14-m 14, Medium, 18 LH
      .text-14-r 14, Regular, 18 LH
      .text-14-m-p 14, Medium, 120% LH
      .text-12-sb-p 12, Semibold, 120% LH
      .text-12-sb 12, Semibold, 16 LH
      .text-12-m-md 12, Medium, 18 LH
      .text-12-r-md 12, Regular, 18 LH
      .text-12-m 12, Medium, 16 LH
      .text-12-m-p 12, Medium, 120% LH
      .text-12-r 12, Regular, 16 LH
      .text-12-r-p 12, Regular, 120% LH
      .text-10-m 10, Medium, 14 LH
      .text-10-r 10, Regular, 14 LH
      .text-10-r-sm 10, Regular, 12 LH
      .text-10-r-p 10, Regular, 120% LH
    .flex.flex-col.gap-y-4.items-start.p-4.border.rounded-md.mb-4
      h2.text-2xl.font-bold.pb-4.border-b.w-full Логотип
      include ../components/logo
    .flex.flex-col.gap-y-4.items-start.p-4.border.rounded-md.mb-4
      h2.text-2xl.font-bold.pb-4.border-b.w-full Поиск
      +search
      +search({
        class: 'transparent',
      })
    .flex.flex-col.gap-y-4.items-start.p-4.border.rounded-md.mb-4
      h2.text-2xl.font-bold.pb-4.border-b.w-full Поля ввода значений
      form(action="#").w-full
        +input({
          type: 'email',
          placeholder: 'Почта',
          isRequired: true,
          name: 'email',
        })
      form(action="#").w-full
        +input({
          type: 'password',
          placeholder: 'Пароль',
          isRequired: true,
          name: 'password',
        })
      form(action="#").w-full
        +input({
          label: 'Наименование',
          type: 'text',
          placeholder: 'Введите наименование',
          isRequired: true,
          isLabel: true,
          name: 'name',
        })
      form(action="#").w-full
        +input({
          label: 'Наименование',
          isLabel: true,
          type: 'text',
          placeholder: 'Введите наименование',
          isRequired: true,
          name: 'name',
          class: 'error',
        })
      form(action="#").w-full
        +input({
          min: '0',
          max: '100',
        })
    .flex.flex-col.gap-y-4.items-start.p-4.border.rounded-md.mb-4
      h2.text-2xl.font-bold.pb-4.border-b.w-full Чекбокс
      form(action="#").w-full.flex.gap-x-4.items-center
        +input({
          type: 'checkbox',
          value: 'Запомнить меня',
        })
        +input({
          type: 'checkbox',
          isChecked: true,
          value: 'Запомнить меня',
        })
        +input({
          type: 'checkbox',
          class: 'lg',
          value: 'Запомнить меня',
        })
        +input({
          type: 'checkbox',
          class: 'input-checkbox-with-label lg',
          isLabel: true,
          label: 'Запомнить меня',
          value: 'Запомнить меня',
        })
    .flex.flex-col.gap-y-4.items-start.p-4.border.rounded-md.mb-4
      h2.text-2xl.font-bold.pb-4.border-b.w-full Кнопка закрытия
      +button({
        view: 'button',
        class: 'button-close',
        icon: 'other-close-icon',
        ariaLabel: 'close',
        isOnlyIcon: true,
      })
    .flex.flex-col.gap-y-4.items-start.p-4.border.rounded-md.mb-4
      h2.text-2xl.font-bold.pb-4.border-b.w-full Боковое меню
      include ../components/sidebar
    .flex.flex-col.gap-y-4.items-start.p-4.border.rounded-md.mb-4
      h2.text-2xl.font-bold.pb-4.border-b.w-full Верхнее меню
      include ../components/header