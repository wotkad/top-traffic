                      alt: 'image',
                      enabled: true,
                      src: '/assets/images/avatar.png',
                    },
                    name: 'curator',
                    title: 'ООО “ИП”',
                  },
                ],
                class: 'dropdown-radios dropdown-copy-image',
                isRadios: true,
                isSearch: true,
                title: '—',
