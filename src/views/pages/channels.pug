extends ../layouts/master

block title
  title Топ Трафик | Справочник каналов

block basicSeo
  meta(content="Справочник каналов страница" name="description")
  meta(content="Справочник каналов, страница" name="keywords")

block manifestBrowserconfigFiles
  link(href="../manifest.json" rel="manifest" crossorigin)
  meta(content="../browserconfig.xml" name="msapplication-config")

block content
  main.page
    include ../components/sidebar
    include ../components/header
    .wrapper
      +heading-table({
        title: 'Каналы',
        count: '50',
        buttons: [
          {
            view: 'button',
            class: 'button-with-icon-blue',
            icon: 'other-plus-icon',
            title: 'Добавить канал',
          },
          {
            view: 'link',
            class: 'button-with-icon',
            icon: 'other-download-icon',
            title: 'Скачать',
            download: true,
          },
          {
            view: 'button',
            class: 'button-with-icon filter__toggle',
            icon: 'other-controls-icon',
            title: 'Фильтр',
            close: true,
          },
        ],
      })
      .inner
        .content
          .content-scroll
            include ../components/table/table-channels
          .mt-12
            include ../components/pagination
        include ../components/filter/filter-channels