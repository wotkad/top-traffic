extends ../layouts/master

block title
  title Топ Трафик | Администраторы

block basicSeo
  meta(content="Администраторы" name="description")
  meta(content="Администраторы" name="keywords")
  meta(content="Администраторы" property="og:title")
  meta(content="Администраторы" name="twitter:title")

block content
  main.page
    include ../components/sidebar
    include ../components/header
    .wrapper
      +heading-table({
        title: 'Администраторы',
        count: '50',
        buttons: [
          {
            view: 'button',
            class: 'button-with-icon-blue',
            icon: 'other-plus-icon',
            title: 'Добавить администратора',
            dataPopupName: 'add-admin',
          },
          {
            view: 'button',
            class: 'button-with-icon filter__toggle',
            icon: 'other-controls-icon',
            title: 'Фильтр',
            isClose: true,
            dataFilterName: 'admins',
          },
        ],
      })
      .inner.in-container
        .content.content-collapsed
          .content-scroll
            include ../components/admins/table
          .mt-12
            include ../components/pagination
        include ../components/admins/filter