extends ../layouts/master

block title
  title Топ Трафик | Клиент

block basicSeo
  meta(content="Клиент" name="description")
  meta(content="Клиент" name="keywords")
  meta(content="Клиент" property="og:title")
  meta(content="Клиент" name="twitter:title")

block content
  main.page
    include ../components/sidebar
    include ../components/header
    .wrapper
      +heading({
        image: {
          alt: 'avatar',
          enabled: true,
          src: '/assets/images/avatar.png',
        },
        isChannel: true,
        tg: '@cybersec_academy',
        title: 'ZeroDay | Кибербезопасность',
      })
      .inner.in-container
        .content.content-sm
          .selectors
            .content.content-not-collapsed
              .selector__buttons
                .selector__scroll
                  .selector__button(data-id="about").active О канале
                  .selector__button(data-id="analytics") Аналитика
              .selector__containers
                .selector__container(data-id="about").active
                  .widgets
                    +widget({
                      icon: 'widget-clock-icon',
                      tip: {
                        content: 'Введенные данные не соответствуют автоматике. Обновите данные',
                        enabled: true,
                      },
                      title: 'Возраст канала',
                      values: [
                        {
                          value: '2 года 11 месяцев',
                        },
                      ],
                    })
                    +widget({
                      icon: 'widget-layout-icon',
                      tip: {
                        content: 'Введенные данные не соответствуют автоматике. Обновите данные',
                        enabled: true,
                      },
                      title: 'Кол-во размещений',
                      values: [
                        {
                          title: 'Активные',
                          value: '1',
                        },
                        {
                          title: 'Всего',
                          value: '25',
                        },
                      ],
                    })
                    +widget({
                      icon: 'widget-users-subscribed-icon',
                      tip: {
                        content: 'Введенные данные не соответствуют автоматике. Обновите данные',
                        enabled: true,
                      },
                      title: 'Подписчики',
                      values: [
                        {
                          class: 'discount',
                          title: '+15% за месяц',
                          value: '22 000 000',
                        },
                      ],
                    })
                    +widget({
                      icon: 'widget-users-icon',
                      tip: {
                        content: 'Введенные данные не соответствуют автоматике. Обновите данные',
                        enabled: true,
                      },
                      title: 'Аудитория',
                      values: [
                        {
                          class: 'male',
                          title: 'М',
                          value: '65%',
                        },
                        {
                          class: 'female',
                          title: 'Ж',
                          value: '35%',
                        },
                      ],
                    })
                .selector__container(data-id="analytics")
                  .widgets
                    +widget({
                      icon: 'widget-consumption-icon',
                      tip: {
                        content: 'Введенные данные не соответствуют автоматике. Обновите данные',
                        enabled: true,
                      },
                      title: 'Общий расход',
                      values: [
                        {
                          value: '20 000 000 ₽',
                        },
                      ],
                    })
                    +widget({
                      icon: 'widget-eye-icon',
                      tip: {
                        content: 'Введенные данные не соответствуют автоматике. Обновите данные',
                        enabled: true,
                        isHidden: true,
                      },
                      title: 'Просмотры (в среднем)',
                      values: [
                        {
                          value: '20 000 000',
                        },
                      ],
                    })
                    +widget({
                      icon: 'widget-users-connected-icon',
                      isFourValues: true,
                      isRows: true,
                      mainValue: '99 803',
                      tip: {
                        content: 'Введенные данные не соответствуют автоматике. Обновите данные',
                        enabled: true,
                      },
                      title: 'Охват',
                      values: [
                        {
                          title: '12 часов',
                          value: '99 803',
                        },
                        {
                          title: '48 часов',
                          value: '99 803',
                        },
                        {
                          title: '24 часов',
                          value: '99 803',
                        },
                        {
                          title: '72 часов',
                          value: '99 803',
                        },
                      ],
                    })
                    +widget({
                      icon: 'widget-favorites-icon',
                      tip: {
                        content: 'Введенные данные не соответствуют автоматике. Обновите данные',
                        enabled: true,
                      },
                      title: 'ERR',
                      values: [
                        {
                          value: '35.59%',
                        },
                      ],
                    })
                    +widget({
                      icon: 'widget-discount-icon',
                      tip: {
                        content: 'Введенные данные не соответствуют автоматике. Обновите данные',
                        enabled: true,
                      },
                      title: 'Последняя скидка',
                      values: [
                        {
                          value: '5%',
                        },
                      ],
                    })
                    +widget({
                      icon: 'widget-eye-icon',
                      tip: {
                        content: 'Введенные данные не соответствуют автоматике. Обновите данные',
                        enabled: true,
                        isHidden: true,
                      },
                      title: 'Просмотры (всего)',
                      values: [
                        {
                          value: '20 000 000',
                        },
                      ],
                    })
                    +widget({
                      icon: 'widget-reply-icon',
                      tip: {
                        content: 'Введенные данные не соответствуют автоматике. Обновите данные',
                        enabled: true,
                      },
                      title: 'ER',
                      values: [
                        {
                          value: '35.59%',
                        },
                      ],
                    })
          .selectors
            .content.content-not-collapsed
              .selector__buttons
                .selector__scroll
                  .selector__button(data-id="channel-statistics").active Статистика канала
                  .selector__button(data-id="publication-statistics") Статистика публикаций
                  .selector__button(data-id="administration-history") История администрирования
                    span 25
                  .selector__button(data-id="advertising-campaigns") Рекламные кампании
                    span 5
                  .selector__button(data-id="transactions-for-payment") Сделки на оплату
                    span 5
              .selector__containers.selector__content
                .selector__container(data-id="channel-statistics").active
                  +heading-table({
                    isSearch: true,
                  })
                  .content-scroll.mt-4
                    include ../components/channel/table
                .selector__container(data-id="publication-statistics")
                  +heading-table({
                    isSearch: true,
                    isCalendar: true,
                    isRows: true,
                    buttons: [
                      {
                        view: 'link',
                        class: 'button-with-icon',
                        icon: 'other-download-icon',
                        title: 'Скачать',
                        isDownload: true,
                      }
                    ],
                  })
                .selector__container(data-id="administration-history")
                  +heading-table({
                    isSearch: true,
                    isRows: true,
                    buttons: [
                      {
                        view: 'button',
                        class: 'button-with-icon-blue',
                        icon: 'other-plus-icon',
                        title: 'Добавить запись',
                        dataPopupName: 'add-administration-history-post',
                      },
                      {
                        view: 'button',
                        class: 'button-with-icon filter__toggle',
                        icon: 'other-controls-icon',
                        title: 'Фильтр',
                        isClose: true,
                        dataFilterName: 'administration-history',
                      },
                    ],
                  })
                .selector__container(data-id="advertising-campaigns")
                  +heading-table({
                    isSearch: true,
                    isRows: true,
                    buttons: [
                      {
                        view: 'button',
                        class: 'button-with-icon filter__toggle',
                        icon: 'other-controls-icon',
                        title: 'Фильтр',
                        isClose: true,
                        dataFilterName: 'advertising-campaigns',
                      },
                    ],
                  })
                  .in-container.mt-4
                    .content.content-collapsed
                      .content-scroll
                        include ../components/advertising-campaigns/table
                      .mt-12
                        include ../components/pagination
                    include ../components/advertising-campaigns/filter
                .selector__container(data-id="transactions-for-payment")
                  +heading-table({
                    isSearch: true,
                    isRows: true,
                    buttons: [
                      {
                        view: 'button',
                        class: 'button-with-icon filter__toggle',
                        icon: 'other-controls-icon',
                        title: 'Фильтр',
                        isClose: true,
                        dataFilterName: 'transactions-for-payment',
                      },
                    ],
                  })
                  .in-container.mt-4
                    .content.content-collapsed
                      .content-scroll
                        include ../components/transactions-for-payment/table
                      .mt-12
                        include ../components/pagination
                    include ../components/transactions-for-payment/filter
        include ../components/channel/aside